rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function myHospitalId() {
      return request.auth.token.hospitalId;
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == 'super_admin';
    }

    function isHospitalAdmin() {
      return isSignedIn() && role() == 'hospital_admin';
    }

    function isPatient() {
      return isSignedIn() && role() == 'patient';
    }

    function isDoctor() {
      return isSignedIn() && role() == 'doctor';
    }

    function isReceptionist() {
      return isSignedIn() && role() == 'receptionist';
    }

    function isStaffOf(hospitalId) {
      return isSignedIn() && myHospitalId() == hospitalId &&
        (role() == 'hospital_admin' || role() == 'receptionist' || role() == 'doctor');
    }

    // -----------------------------------------------------------------
    // hospitals — BUG FIX: create is super_admin-only (unchanged), but
    // update must also allow a hospital_admin to modify THEIR OWN
    // hospital doc — this is what SkipPolicyScreen (Phase 5) needs and
    // was silently broken under the old single "allow write" rule.
    // -----------------------------------------------------------------
    match /hospitals/{hospitalId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isHospitalAdmin() && myHospitalId() == hospitalId);
      allow delete: if isSuperAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() ||
        (isHospitalAdmin() && myHospitalId() == request.resource.data.hospitalId);
      allow update, delete: if isSuperAdmin() ||
        (isHospitalAdmin() && myHospitalId() == resource.data.hospitalId);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        isStaffOf(resource.data.hospitalId)
      );
      allow create: if isSuperAdmin() ||
        (isHospitalAdmin() &&
         myHospitalId() == request.resource.data.hospitalId &&
         request.resource.data.role in ['receptionist', 'doctor']) ||
        (isSignedIn() &&
         request.auth.uid == userId &&
         request.resource.data.role == 'patient' &&
         request.resource.data.hospitalId == null);
      allow update: if request.auth.uid == userId || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // doctors — TIGHTENED. No client code path writes here anymore —
    // creation happens inside createStaffAccount (Admin SDK), and
    // avgConsultationMinutes/recentConsultationDurations updates happen
    // inside consultationAverages.js (also Admin SDK). Both bypass rules
    // entirely, so client write access here was pure unused surface.
    // -----------------------------------------------------------------
    match /doctors/{doctorId} {
         allow read: if isSignedIn();
         allow create, delete: if false;
         allow update: if isSuperAdmin() ||
            (isHospitalAdmin() && myHospitalId() == resource.data.hospitalId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['departmentId']));
        }

    // -----------------------------------------------------------------
    // appointments — 'create' TIGHTENED to false. Every appointment is
    // now created server-side via createAppointment / createReferral /
    // createFollowUpAppointment (all Admin SDK callables) — no client
    // path writes a new appointments doc directly anymore. 'update'
    // stays open to staff, since QueueRepository.checkIn() still does a
    // direct client update of status → 'checked_in'.
    // -----------------------------------------------------------------
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
        (isPatient() && request.auth.uid == resource.data.patientId) ||
        isStaffOf(resource.data.hospitalId) ||
        isSuperAdmin()
      );
      allow create: if false;
      allow update: if isStaffOf(resource.data.hospitalId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // queue_entries — 'create' TIGHTENED to receptionist/doctor only
    // (hospital_admin has no legitimate check-in action in the built
    // app). 'update' SPLIT BY ROLE: a doctor may update anything (status
    // transitions, pause/resume, skip — all doctor-only actions in the
    // UI, now also enforced here); a receptionist may ONLY change
    // priority/priorityRank (their one legitimate write — escalatePriority),
    // not status or doctorId. This closes the gap where any staff member
    // could previously have written an arbitrary status transition
    // directly, bypassing the doctor-only intent of the app's own UI.
    // -----------------------------------------------------------------
    match /queue_entries/{hospitalId}/{date}/{departmentId}/entries/{entryId} {
      allow read: if isSignedIn() && (
        (isPatient() && request.auth.uid == resource.data.patientId) ||
        isStaffOf(hospitalId) ||
        isSuperAdmin()
      );
      allow create: if isSuperAdmin() ||
        ((isReceptionist() || isDoctor()) && myHospitalId() == hospitalId);
      allow update: if isSuperAdmin() ||
        (isDoctor() && myHospitalId() == hospitalId) ||
        (isReceptionist() && myHospitalId() == hospitalId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['priority', 'priorityRank']));
      allow delete: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // counters — TIGHTENED to fully server-only. Every counter increment
    // now happens inside a Firestore transaction within createAppointment /
    // createReferral / createFollowUpAppointment (Admin SDK) — no client
    // write path exists anymore. Read access kept for staff in case a
    // future screen wants to display today's token count.
    // -----------------------------------------------------------------
    match /counters/{counterId} {
      allow read: if isSuperAdmin() || isStaffOf(resource.data.hospitalId);
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // visits — TIGHTENED to fully server-only. Created and (never)
    // updated only inside createReferral (Admin SDK) — no client write
    // path exists.
    // -----------------------------------------------------------------
    match /visits/{visitId} {
      allow read: if isSignedIn() && (
        (isPatient() && request.auth.uid == resource.data.patientId) ||
        isStaffOf(resource.data.hospitalId) ||
        isSuperAdmin()
      );
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // notifications — 'create' TIGHTENED to false. All notifications are
    // now written by onQueueEntryWritten (Admin SDK) — no client ever
    // creates one directly. 'update' stays open for markAsRead, which IS
    // a real client write path (notifications_screen.dart).
    // -----------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if false;
      allow delete: if isSuperAdmin();
    }

    match /sms_emulator/{docId} {
      allow read: if isSuperAdmin() || isHospitalAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}